<Window x:Class="Zzapcho.Launcher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="zzapcho Launcher"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize">
    <Grid Background="{StaticResource CharcoalBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#252538"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="─" Width="46" Height="36" Padding="0" BorderThickness="0" Background="Transparent" Click="Minimize_Click" />
                    <Button Content="✕" Width="46" Height="36" Padding="0" BorderThickness="0" Background="Transparent" Foreground="{StaticResource MutedTextBrush}" Click="Close_Click" />
                </StackPanel>
                <TextBlock Text="zzapcho Launcher"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="#252538"
                    BorderThickness="0,0,1,0"
                    Padding="8,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="8" Padding="10,9" Margin="0,0,0,12">
                            <DockPanel>
                                <Border Width="32" Height="32" CornerRadius="4" Background="{StaticResource GoldBrush}" DockPanel.Dock="Left" Margin="0,0,10,0">
                                    <TextBlock Text="Z" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{Binding Account.PlayerName}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Account.Status}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <ListBox ItemsSource="{Binding NavigationItems}"
                                 SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource IvoryBrush}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,0,2" />
                                    <Setter Property="Padding" Value="10,8" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBorder" CornerRadius="6" Background="Transparent">
                                                    <ContentPresenter Margin="{TemplateBinding Padding}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#242442" />
                                                        <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#222235" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom">
                        <Button Content="Microsoft 로그인" Command="{Binding Account.LoginCommand}" Margin="0,0,0,6" />
                        <Button Content="로그아웃" Command="{Binding Account.LogoutCommand}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentViewModel}"
                            Margin="28" />
        </Grid>
    </Grid>
</Window>
