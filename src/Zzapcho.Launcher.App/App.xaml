<Application x:Class="Zzapcho.Launcher.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Zzapcho.Launcher.App.ViewModels"
             xmlns:views="clr-namespace:Zzapcho.Launcher.App.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="CharcoalColor">#0F0F17</Color>
        <Color x:Key="PanelColor">#161625</Color>
        <Color x:Key="SoftPanelColor">#1E1E30</Color>
        <Color x:Key="IvoryColor">#FFFFFF</Color>
        <Color x:Key="MutedTextColor">#8E8E9A</Color>
        <Color x:Key="GoldColor">#5865F2</Color>
        <Color x:Key="GoldSoftColor">#A855F7</Color>
        <Color x:Key="GreenColor">#57F287</Color>
        <Color x:Key="RedColor">#ED4245</Color>

        <SolidColorBrush x:Key="CharcoalBrush" Color="{StaticResource CharcoalColor}" />
        <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
        <SolidColorBrush x:Key="SoftPanelBrush" Color="{StaticResource SoftPanelColor}" />
        <SolidColorBrush x:Key="IvoryBrush" Color="{StaticResource IvoryColor}" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
        <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}" />
        <SolidColorBrush x:Key="GoldSoftBrush" Color="{StaticResource GoldSoftColor}" />
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
        <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic" />
            <Setter Property="Background" Value="{StaticResource CharcoalBrush}" />
            <Setter Property="Foreground" Value="{StaticResource IvoryBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource IvoryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="UserControl">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.22" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="20" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SoftPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource IvoryBrush}" />
            <Setter Property="BorderBrush" Value="#2B2B3D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.92" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource GreenBrush}" />
            <Setter Property="Foreground" Value="#0A2E14" />
            <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="26,14" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="#332F2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="24" />
        </Style>
        <Style x:Key="TinyBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftPanelBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,4" />
        </Style>

        <DataTemplate DataType="{x:Type vm:PlayViewModel}">
            <views:PlayView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UpdateViewModel}">
            <views:UpdateView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FileCategoryViewModel}">
            <views:FileCategoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView />
        </DataTemplate>
    </Application.Resources>
</Application>
