<UserControl x:Class="Zzapcho.Launcher.App.Views.PlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="Minecraft" Foreground="{StaticResource MutedTextBrush}" FontSize="14" VerticalAlignment="Center" />
                <Border Style="{StaticResource TinyBadge}" Margin="8,0,0,0">
                    <TextBlock Text="{Binding Status.Version}" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="13" />
                </Border>
                <Border Style="{StaticResource TinyBadge}" Margin="8,0,0,0">
                    <TextBlock Text="Fabric" Foreground="#96D636" FontWeight="Bold" FontSize="12" />
                </Border>
            </StackPanel>

            <Border Background="{StaticResource SoftPanelBrush}" BorderBrush="#2B2B3D" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,18">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding ClientMessage}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <TextBlock DockPanel.Dock="Right" Text="{Binding Status.StateText}" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="12" />
                    </DockPanel>
                    <ProgressBar Height="4" Margin="0,10,0,0" Value="35" Foreground="{StaticResource GoldBrush}" Background="#252538" />
                </StackPanel>
            </Border>

            <Button Command="{Binding PlayCommand}"
                    IsEnabled="{Binding IsPrimaryEnabled}"
                    Style="{StaticResource PrimaryButton}"
                    Height="64"
                    Width="240"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="▶" Margin="0,0,10,0" FontSize="16" />
                    <TextBlock Text="{Binding PrimaryButtonText}" FontSize="18" FontWeight="Bold" />
                </StackPanel>
            </Button>

            <StackPanel Margin="0,20,0,0">
                <Border Background="{StaticResource SoftPanelBrush}" BorderBrush="#2B2B3D" BorderThickness="1" CornerRadius="8" Padding="12,9">
                    <DockPanel>
                        <Ellipse DockPanel.Dock="Left" Width="7" Height="7" Fill="{StaticResource GreenBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding Host}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <TextBlock DockPanel.Dock="Right" Text="{Binding PlayerSummary}" Foreground="{StaticResource GreenBrush}" FontWeight="Bold" FontSize="11" />
                    </DockPanel>
                </Border>
                <TextBlock Text="{Binding Status.Motd}" Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,10,0,0" />
                <Button Content="서버 상태 새로고침" Command="{Binding RefreshCommand}" HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="#252538" BorderThickness="1" CornerRadius="6" Padding="12,8" HorizontalAlignment="Center" Margin="0,42,0,0">
                <TextBlock Text="기본" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
