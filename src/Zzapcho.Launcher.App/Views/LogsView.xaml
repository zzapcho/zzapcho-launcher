<UserControl x:Class="Zzapcho.Launcher.App.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="로그" FontSize="32" FontWeight="SemiBold" />
            <TextBlock Text="문제가 생겼을 때 확인할 수 있는 기록입니다."
                       Style="{StaticResource MutedText}"
                       Margin="0,8,0,26" />
        </StackPanel>

        <DockPanel Grid.Row="1" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <ListBox ItemsSource="{Binding LogNames}"
                         SelectedItem="{Binding SelectedLogName, Mode=TwoWay}"
                         Width="150"
                         Height="38" />
                <Button Content="다시 읽기"
                        Command="{Binding LoadLogCommand}"
                        Margin="12,0,0,0" />
            </StackPanel>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="260"
                     Height="38"
                     VerticalContentAlignment="Center"
                     DockPanel.Dock="Right" />
        </DockPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <TextBox Text="{Binding FilteredLogText}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Background="#151413"
                     Foreground="{StaticResource IvoryBrush}"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="13"
                     Padding="18" />
        </Border>

        <DockPanel Grid.Row="3" Margin="0,18,0,0">
            <TextBlock Text="{Binding SupportZipStatus}"
                       Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="복사" Command="{Binding CopyCommand}" Margin="0,0,10,0" />
                <Button Content="로그 폴더 열기" Command="{Binding OpenLogsFolderCommand}" Margin="0,0,10,0" />
                <Button Content="지원 ZIP 만들기" Command="{Binding CreateSupportZipCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
