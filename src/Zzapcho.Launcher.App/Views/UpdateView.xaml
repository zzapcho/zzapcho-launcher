<UserControl x:Class="Zzapcho.Launcher.App.Views.UpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="SemiBold" />
            <TextBlock Text="런처와 클라이언트 상태를 조용하게 확인합니다."
                       Style="{StaticResource MutedText}"
                       Margin="0,8,0,30" />
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding Status}" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Detail}"
                               Style="{StaticResource MutedText}"
                               Margin="0,12,0,22" />

                    <UniformGrid Columns="2" Rows="4">
                        <StackPanel Margin="0,0,22,16">
                            <TextBlock Text="manifest 버전" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding ManifestVersion}" FontSize="17" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,22,16">
                            <TextBlock Text="Minecraft 버전" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding MinecraftVersion}" FontSize="17" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,22,16">
                            <TextBlock Text="로더" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding LoaderVersion}" FontSize="17" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,22,16">
                            <TextBlock Text="manifest hash" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding ManifestHash}" FontSize="12" />
                        </StackPanel>
                        <StackPanel Margin="0,0,22,16">
                            <TextBlock Text="검사한 파일" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding FilesChecked}" FontSize="17" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,22,16">
                            <TextBlock Text="다운로드" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding FilesDownloaded}" FontSize="17" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,22,0">
                            <TextBlock Text="복구 필요" Style="{StaticResource MutedText}" />
                            <TextBlock FontSize="17" FontWeight="SemiBold">
                                <Run Text="{Binding FilesMissing}" />
                                <Run Text=" 누락 / " />
                                <Run Text="{Binding FilesInvalid}" />
                                <Run Text=" 손상" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="0,0,22,0">
                            <TextBlock Text="격리한 파일" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding FilesQuarantined}" FontSize="17" FontWeight="SemiBold" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="{Binding Messages}"
                               Style="{StaticResource MutedText}"
                               Margin="0,16,0,0" />

                    <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                        <Button Content="다시 검사" Command="{Binding CheckCommand}" Margin="0,0,10,0" />
                        <Button Content="복구" Command="{Binding RepairCommand}" Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
