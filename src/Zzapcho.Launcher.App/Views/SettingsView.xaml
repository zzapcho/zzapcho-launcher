<UserControl x:Class="Zzapcho.Launcher.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="설정" FontSize="32" FontWeight="SemiBold" />
        <TextBlock Text="이 PC에서 사용할 런처 설정입니다."
                   Style="{StaticResource MutedText}"
                   Margin="0,8,0,30" />

        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="최소 메모리(MB)" Style="{StaticResource MutedText}" />
                <TextBox Grid.Column="1"
                         Text="{Binding RamMinMb, UpdateSourceTrigger=PropertyChanged}"
                         Height="36"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="1" Text="최대 메모리(MB)" Style="{StaticResource MutedText}" Margin="0,18,0,0" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding RamMaxMb, UpdateSourceTrigger=PropertyChanged}"
                         Height="36"
                         Margin="0,18,0,0"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2" Text="자동 업데이트" Style="{StaticResource MutedText}" Margin="0,18,0,0" />
                <CheckBox Grid.Row="2"
                          Grid.Column="1"
                          IsChecked="{Binding AutoUpdate}"
                          Content="시작 시 업데이트 확인"
                          Foreground="{StaticResource IvoryBrush}"
                          Margin="0,18,0,0" />

                <TextBlock Grid.Row="3" Text="크래시 리포트" Style="{StaticResource MutedText}" Margin="0,18,0,0" />
                <CheckBox Grid.Row="3"
                          Grid.Column="1"
                          IsChecked="{Binding CrashReportConsent}"
                          Content="동의한 경우에만 전송"
                          Foreground="{StaticResource IvoryBrush}"
                          Margin="0,18,0,0" />

                <TextBlock Grid.Row="4" Text="manifest URL" Style="{StaticResource MutedText}" Margin="0,18,0,0" />
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Text="{Binding ManifestUrl, UpdateSourceTrigger=PropertyChanged}"
                         Height="36"
                         Margin="0,18,0,0"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="5" Text="런처 업데이트 저장소" Style="{StaticResource MutedText}" Margin="0,18,0,0" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Text="{Binding LauncherUpdateSourceUrl, UpdateSourceTrigger=PropertyChanged}"
                         Height="36"
                         Margin="0,18,0,0"
                         VerticalContentAlignment="Center" />
            </Grid>
        </Border>

        <DockPanel Margin="0,18,0,0">
            <TextBlock Text="{Binding Status}"
                       Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="데이터 폴더 열기" Command="{Binding OpenDataFolderCommand}" Margin="0,0,10,0" />
                <Button Content="기본값으로" Command="{Binding ResetCommand}" Margin="0,0,10,0" />
                <Button Content="저장" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </DockPanel>
    </StackPanel>
</UserControl>
