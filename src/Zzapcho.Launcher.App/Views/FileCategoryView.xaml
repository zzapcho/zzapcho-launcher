<UserControl x:Class="Zzapcho.Launcher.App.Views.FileCategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="브라우저" Command="{Binding BrowseCommand}" Margin="0,0,6,0" />
                <Button Content="+ 파일 추가" Command="{Binding AddFileCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" />
        </DockPanel>

        <Border Grid.Row="1" BorderBrush="#39405F" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,18">
            <TextBlock Text="{Binding DropText}" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="서버 파일" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="Bold" />
            <ListBox Grid.Row="1" ItemsSource="{Binding ServerFiles}" Background="Transparent" BorderThickness="0" Margin="0,6,0,16">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SoftPanelBrush}" BorderBrush="#2B2B3D" BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,4">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Background="#25294B" CornerRadius="3" Padding="6,2">
                                    <TextBlock Text="서버" Foreground="{StaticResource GoldBrush}" FontSize="10" FontWeight="Bold" />
                                </Border>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2" Text="내 파일" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="Bold" />
            <ListBox Grid.Row="3" ItemsSource="{Binding UserFiles}" Background="Transparent" BorderThickness="0" Margin="0,6,0,16" />

            <DockPanel Grid.Row="4">
                <TextBlock Text="{Binding Status}" Style="{StaticResource MutedText}" />
                <Button DockPanel.Dock="Right" Content="새로고침" Command="{Binding RefreshCommand}" />
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
